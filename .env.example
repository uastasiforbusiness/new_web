# PostgreSQL connection string for Docker local setup
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/bleader_db?schema=public"

# ─── Rate limiting (optional — falls back to in-memory if unset) ───
# Get these from Vercel → Storage → KV (or Upstash dashboard).
# Without these, rate limiting uses a per-instance in-memory limiter
# (works locally, not effective in serverless production).
KV_REST_API_URL=https://example.upstash.io
KV_REST_API_TOKEN=***

# ─── Email notifications via Resend (optional — emails skipped if unset) ───
# Get your API key from https://resend.com/api-keys
# RESEND_FROM defaults to onboarding@resend.dev (pre-verified for testing).
# For production, verify your own domain and use e.g. noreply@bleader.com.
RESEND_API_KEY=re_xxx_***
RESEND_FROM=onboarding@resend.dev
RESEND_ADMIN_TO=your-email@example.com
# DEMO MODE: when "false", customer emails go to the real customer address.
# When unset/anything else, ALL emails route to ADMIN_TO (account owner).
# Needed because onboarding@resend.dev can only send to the owner.
# Set RESEND_DEMO_MODE=false once you verify your own domain in Resend.
RESEND_DEMO_MODE=true

# ─── WhatsApp Cloud API ──────────────────────────────────────────────────
# DEMO=true for development without Meta account. Flip to false once your
# Meta Business number is approved and you have:
# 1) WHATSAPP_TOKEN (permanent access token from Meta)
# 2) WHATSAPP_PHONE_NUMBER_ID (from Meta Business dashboard)
# 3) WHATSAPP_VERIFY_TOKEN (custom token for webhook verification)
# 4) WHATSAPP_APP_SECRET (for HMAC signature verification)
WHATSAPP_DEMO_MODE=true
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_APP_SECRET=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_GRAPH_API_VERSION=v21.0