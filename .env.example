# Environment Variables Example for B LEADER App
# This file documents all required and recommended variables for development and production
# Copy to .env and adjust for your environment

# ---------- Database (D1) ----------
# (No secret needed for local DB — use `npx wrangler d1 execute ...` manually)

# ---------- Resend Email Service ----------
RESEND_API_KEY=""
RESEND_FROM="onboarding@resend.dev"
RESEND_DEMO_MODE="true" # Set to "false" once you verify your own domain
RESEND_ADMIN_TO="uastasiforbusiness@gmail.com"

# ---------- WhatsApp Business API (Meta) ----------
# Required for /api/whatsapp/* routes (Cloudflare Worker secrets in prod)
# wrangler secret put WHATSAPP_TOKEN
# wrangler secret put WHATSAPP_PHONE_NUMBER_ID
# wrangler secret put WHATSAPP_APP_SECRET
# wrangler secret put WHATSAPP_VERIFY_TOKEN
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_TOKEN=""
WHATSAPP_APP_SECRET=""
WHATSAPP_VERIFY_TOKEN=""
WHATSAPP_GRAPH_API_VERSION="v25.0"
# Approved template for first business-initiated message (Meta default: hello_world)
WHATSAPP_TEMPLATE_NAME="hello_world"
WHATSAPP_TEMPLATE_LANG="en_US"


# ---------- Cloudflare & Rate Limiting ----------
# For production rate limiting (optional for local dev)
KV_REST_API_URL=""
KV_REST_API_TOKEN=""

# ---------- Security / CSRF ----------
# Allowed origins for reservation form
CSRF_ALLOWED_ORIGINS="http://localhost:3000,http://localhost:3001,https://bleaderitaly.com,https://www.bleaderitaly.com,https://bleaderitaly.it,https://www.bleaderitaly.it,https://bleader-italy.uastasiforbusiness.workers.dev,https://bleader-italy.pages.dev"

# ---------- Site / SEO (official domains) ----------
# Primary public site URL (canonical, Open Graph, sitemap)
NEXT_PUBLIC_SITE_URL="https://bleaderitaly.com"
# NEXT_PUBLIC_SITE_URL="https://bleaderitaly.it"  # Italian apex if preferred
NEXT_PUBLIC_EMAIL="info@bleaderitaly.com"
# E.164 phone for schema + contact (no placeholder in production HTML)
# NEXT_PUBLIC_PHONE="+39..."
# Optional LocalBusiness address / geo (WGS84)
# NEXT_PUBLIC_STREET_ADDRESS=""
# NEXT_PUBLIC_ADDRESS_LOCALITY="Lecce"
# NEXT_PUBLIC_ADDRESS_REGION="Puglia"
# NEXT_PUBLIC_POSTAL_CODE=""
# NEXT_PUBLIC_GEO_LAT="40.3515"
# NEXT_PUBLIC_GEO_LNG="18.1750"

# Search Console / Bing Webmaster verification meta tokens (public)
# NEXT_PUBLIC_GOOGLE_VERIFICATION=""
# NEXT_PUBLIC_BING_VERIFICATION=""

# Brand entity — social profiles for JSON-LD sameAs (https URLs only)
# Comma-separated list OR individual vars (both merge + dedupe)
# NEXT_PUBLIC_SAME_AS="https://www.instagram.com/...,https://www.facebook.com/..."
# NEXT_PUBLIC_SOCIAL_INSTAGRAM="https://www.instagram.com/..."
# NEXT_PUBLIC_SOCIAL_FACEBOOK="https://www.facebook.com/..."
# NEXT_PUBLIC_SOCIAL_X="https://x.com/..."
# NEXT_PUBLIC_SOCIAL_LINKEDIN="https://www.linkedin.com/company/..."
# NEXT_PUBLIC_SOCIAL_YOUTUBE="https://www.youtube.com/@..."
# NEXT_PUBLIC_SOCIAL_TRIPADVISOR="https://www.tripadvisor.com/..."
# NEXT_PUBLIC_TWITTER_HANDLE="@..."

# ---------- General ----------
NODE_ENV="development"
NEXT_PUBLIC_URL="http://localhost:3001"

# ---------- Notas Importantes ----------
# - Si no configuras RESEND_API_KEY, los emails no se enviarán (solo logs).
# - Si no configuras KV vars, usarás el limiter in-memory.
# - Set RESEND_DEMO_MODE=false cuando uses tu propio dominio email en Resend.
# - WhatsApp requiere Phone Number ID y Token válidos.

# ---------- Para Producción ----------
# Usa `wrangler secret put RESEND_API_KEY ...` etc., y configura tus Workers.
