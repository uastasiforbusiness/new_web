{
  "name": "nextjs_tailwind_shadcn_ts",
  "version": "0.2.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3001 --webpack",
    "build": "npm run cf:typegen && opennextjs-cloudflare build",
    "start": "next start -p 3000",
    "lint": "eslint .",
    "postinstall": "prisma generate",
    "cf:build": "npm run cf:typegen && opennextjs-cloudflare build",
    "cf:preview": "npm run cf:build && opennextjs-cloudflare preview",
    "cf:deploy": "npm run cf:build && wrangler deploy --autoconfig=false",
    "cf:upload": "npm run cf:build && opennextjs-cloudflare upload",
    "cf:typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "db:push": "prisma db push",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:reset": "prisma migrate reset"
  },
  "packageManager": "npm@10",
  "dependencies": {
    "@opennextjs/cloudflare": "^1.20.1",
    "@prisma/adapter-d1": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.38.0",
    "clsx": "^2.1.1",
    "framer-motion": "^12.23.2",
    "gsap": "^3.15.0",
    "lenis": "^1.3.23",
    "lucide-react": "^0.525.0",
    "next": "^16.1.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "resend": "^6.14.0",
    "tailwind-merge": "^3.3.1",
    "zod": "^4.0.2"
  },
  "devDependencies": {
    "@prisma/config": "7.8.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "25.9.2",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "^16.1.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "prisma": "^7.8.0",
    "sharp": "^0.34.5",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.3.5",
    "typescript": "^5",
    "wrangler": "^4"
  },
  "eslintConfig": {
    "extends": [
      "next/core-web-vitals"
    ],
    "plugins": [
      "@typescript-eslint",
      "react-hooks"
    ]
  }
}